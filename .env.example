# Google Cloud Platform Service Account Credentials
GCP_PROJECT_ID=your_project_id
GCP_PRIVATE_KEY_ID=your_private_key_id
# Note: Ensure the private key retains its newline characters, or replace them with \n
GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GCP_CLIENT_EMAIL=your_service_account_email@your_project.iam.gserviceaccount.com
GCP_CLIENT_ID=your_client_id
GCP_CLIENT_X509_CERT_URL=your_cert_url

# Target Google Sheet (URL)
SPREADSHEET_URL=https://docs.google.com/spreadsheets/d/your_spreadsheet_id/edit
